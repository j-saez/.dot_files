#!/bin/bash

BOLD='\033[1m'
WHITE='\033[0;37m'
RED='\033[0;31m'
YELLOW='\033[0;33m'
RESET='\033[0m'

sessions=$(tmux list-sessions -F "#S")

if [ -z "$sessions" ]; then
  echo "No active tmux sessions found."
  exit 0
fi

selected=$(echo "$sessions" | fzf --multi --reverse --preview "tmux list-windows -t {}" \
  --header "Select sessions to kill (Tab to multi-select, Enter to confirm):")

if [ -z "$selected" ]; then
  echo "No session selected."
  exit 0
fi

echo -e "${WHITE}Sessions to kill:${RESET}"
while IFS= read -r session; do
  echo -e "  ${YELLOW}- ${BOLD}${RED}${session}${RESET}"
done <<< "$selected"

echo -en "${BOLD}${YELLOW}Are you sure? (y/n): ${RESET}"
read confirm
if [ "$confirm" != "y" ]; then
  echo -e "${YELLOW}Aborted.${RESET}"
  exit 0
fi

while IFS= read -r session; do
  if tmux kill-session -t "$session"; then
    echo -e "${YELLOW}Killed ${BOLD}${RED}${session}${RESET}${YELLOW}.${RESET}"
  else
    echo -e "${YELLOW}Failed to kill ${BOLD}${RED}${session}${RESET}${YELLOW}.${RESET}"
  fi
done <<< "$selected"
