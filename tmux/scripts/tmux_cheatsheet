#!/bin/bash

bold=$(tput bold)
reset=$(tput sgr0)
cat_color=$(tput setaf 6)  # cyan
key_color=$(tput setaf 3)  # yellow

# category|key|description
entries=(
"Session|prefix + n|new session (prompts for name)"
"Session|prefix + s|switch session"
"Session|prefix + k|kill session"
"Session|prefix + \$|rename session"
"Session|prefix + f|worktree sessionizer (fzf across all git worktrees)"
"Session|prefix + N|new worktree (create branch + open session)"
"Session|prefix + e|exec into indoor_uav dev container at pane's path"
"Window|prefix + c|new window"
"Window|prefix + w|switch window (fzf picker)"
"Window|prefix + 0-9|jump to window by number"
"Window|prefix + p|previous window"
"Window|prefix + ,|rename window"
"Window|Alt-m / Alt-n|prev / next window (no prefix)"
"Window|Alt-, / Alt-.|swap window left / right"
"Pane|prefix + v|split vertical (side by side)"
"Pane|prefix + a|split horizontal (stacked)"
"Pane|Alt-h/j/k/l|move between panes"
"Pane|Alt-H/J/K/L|resize pane"
"Copy|prefix + [|enter copy mode"
"Copy|v|start selection (inside copy mode)"
"Copy|y|copy selection to clipboard"
"Copy|Ctrl-p|paste buffer"
"Misc|prefix + g|open lazygit"
"Misc|prefix + r|reload config"
"Misc|prefix + ?|this cheatsheet"
"Save|prefix + Ctrl-s|save sessions/windows/panes (resurrect)"
"Save|prefix + Ctrl-r|restore last save"
)

printf '%s\n' "${entries[@]}" | awk -F'|' -v c="$cat_color" -v k="$key_color" -v b="$bold" -v r="$reset" '{
    printf "%s%-8s%s  %s%-20s%s  %s\n", c, $1, r, b k, $2, r, $3
}' | fzf --ansi \
         --prompt="tmux cheatsheet> " \
         --header="Prefix: Ctrl-b   (type to filter, Esc/Enter to close)" \
         --no-info \
         --layout=reverse \
         --bind "enter:accept,esc:accept"
